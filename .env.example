# Copy to .env and fill in. `.env` is gitignored.
# `make fork-test` and `make demo` require MAINNET_RPC_URL.
# Mainnet broadcasts via `forge script ... --broadcast` need PRIVATE_KEY too.

# Required for fork tests and anvil-demo.
# Free tier from Alchemy, Infura, drpc.org, llamarpc, etc. is sufficient —
# any HTTPS Ethereum mainnet endpoint will do.
MAINNET_RPC_URL=

# Required only when broadcasting to mainnet.
# Don't paste a real key into shells you don't trust; prefer `cast wallet` or
# a hardware wallet for production deploys.
PRIVATE_KEY=

# Optional — enables `forge verify-contract` to push source to Etherscan.
ETHERSCAN_API_KEY=
