# Ethereum RPC
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Agent wallet (EOA that submits reconfigure txs)
PRIVATE_KEY=0x...

# Pool addresses
POOL_ADDRESS=0x...
HOOK_ADDRESS=0x...

# EVC (Ethereum Vault Connector) — required for reconfigure calls
EVC_ADDRESS=0x...
# The pool owner's EVC account (eulerAccount from StaticParams)
EULER_ACCOUNT=0x...

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Flashbots Protect RPC for mainnet
FLASHBOTS_RPC_URL=https://rpc.flashbots.net

# Polling intervals (seconds)
POLL_INTERVAL=30
CLAUDE_REVIEW_INTERVAL=3600

# Gas budget (ETH per day)
DAILY_GAS_BUDGET=0.1
