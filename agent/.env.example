# Ethereum RPC
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Agent wallet private key (same EOA that deployed the pool)
PRIVATE_KEY=0x...

# Pool addresses (from DeployMainnet.s.sol output — "Copy to agent/.env.mainnet")
POOL_ADDRESS=0x...
HOOK_ADDRESS=0x...

# EVC (Ethereum Vault Connector) — required for reconfigure calls
# Mainnet: 0x0C9a3dd6b8F28529d72d7f9cE918D493519EE383
EVC_ADDRESS=0x0C9a3dd6b8F28529d72d7f9cE918D493519EE383
# The deployer EOA address (eulerAccount from StaticParams)
EULER_ACCOUNT=0x...

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Flashbots RPC for MEV protection on reconfigure txs
FLASHBOTS_RPC_URL=https://rpc.flashbots.net

# Polling intervals (seconds)
POLL_INTERVAL=30           # How often to read on-chain state (no gas cost)
CLAUDE_REVIEW_INTERVAL=3600  # How often Claude reviews strategy (1 hour)

# Gas budget (ETH per day) — hard stop on agent spending
# Scale this with pool TVL: 0.01 for $1K pool, 0.1 for $10K+
DAILY_GAS_BUDGET=0.01

# External swap (CowSwap) — slippage tolerance in basis points
# Swaps are last-resort rebalancing, capped at 10% of reserves per swap
SWAP_SLIPPAGE_BPS=50

# Perp funding rate feed — set to the volatile asset symbol (e.g. ETH, BTC)
# Used by Claude to orient fee asymmetry toward funding-profitable direction
# Leave unset for stablecoin-only pools
# FUNDING_SYMBOL=ETH
